DISCORD_TOKEN=
RIOT_API=
SPOTIFY_CLIENT_ID=
SPOTIFY_SECRET_KEY=

# Lavalink 설정 (다중 노드 지원)
# LAVALINK_PASSWORD: 모든 노드 공통 비밀번호 (docker-compose healthcheck와도 공유)
LAVALINK_PASSWORD=youshallnotpass
# LAVALINK_NODES: JSON 배열로 노드 정의. 각 노드는 identifier(필수), host(필수), port(선택·기본 2333)
# 노드 추가/삭제는 이 배열만 수정하면 됨 (docker-compose에 노드 서비스도 함께 추가 필요)
# 단일 노드 예:
#   LAVALINK_NODES=[{"identifier":"node1","host":"lavalink"}]
# 다중 노드 예:
#   LAVALINK_NODES=[{"identifier":"node1","host":"lavalink"},{"identifier":"node2","host":"lavalink2","port":2334}]
LAVALINK_NODES=[{"identifier":"node1","host":"lavalink"}]
AUTO_DISCONNECT_TIMEOUT=600